# 灯(Tomoshibi) 環境設定サンプル — コピーして `.env` を作成
# すべてオプション。未設定ならモックで動作します。

# ---- 実行モード ----
# auto: 利用可能なバックエンドを自動検出（無ければmock）
# mock: 全モデルをモック化（Mac開発・UI確認・ロジック検証用）
# real: 実モデルを強制（Ryzen AI PC）
TOMOSHIBI_MODE=auto

# ---- 対話LLM (LFM2) ----
# llama.cpp(GGUF)経由を優先。日本語チューニング版 LFM2.5-1.2B-JP を既定に。
LFM2_GGUF_PATH=models/LFM2.5-1.2B-JP-Q4_K_M.gguf
LFM2_HF_ID=LiquidAI/LFM2.5-1.2B-JP-202606
# llama.cpp サーバのエンドポイント。設定すると実LFM2対話が有効化される。
# 起動: bash scripts/run_llm_server.sh
LLAMACPP_SERVER_URL=http://127.0.0.1:8080

# ---- 視覚 (LFM2-VL, 転倒確認) ----
LFM2_VL_HF_ID=LiquidAI/LFM2-VL-450M

# ---- 音声 ----
# TTS: voicevox | lfm_audio | mock
# VOICEVOX はこのプロジェクト所有のエンジンを使う: `bash scripts/run_voicevox.sh`（docker compose）。
# 別プロジェクトが50021を使用中なら VOICEVOX_PORT=50121 等で衝突回避し、VOICEVOX_URL も合わせる。
TTS_BACKEND=voicevox
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_PORT=50021
VOICEVOX_SPEAKER=3
# 話し相手の話速（高齢者向けに ゆっくり。1.0=標準, 0.85=やや遅い）。転倒検知の発話は常に1.0。
COMPANION_SPEECH_SPEED=0.85
# ASR: whisper_cpp（Ryzen実機） | faster_whisper（Mac開発・torch不要） | mock
ASR_BACKEND=faster_whisper
WHISPER_CPP_BIN=whisper-cli
WHISPER_CPP_MODEL=models/ggml-base.bin
FASTER_WHISPER_MODEL=base   # tiny|base|small|medium

# ---- 家族通知 ----
# channel: mock | webhook | line_notify
FAMILY_NOTIFY_CHANNEL=mock
FAMILY_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=

# ---- 観測性 (W&B Weave) ----
WANDB_API_KEY=
WEAVE_PROJECT=tomoshibi
TOMOSHIBI_ENABLE_WEAVE=0

# ---- 見守りカメラ（cv2 + MediaPipe → LFM2-VL） ----
GUARDIAN_CAMERA_INDEX=0
GUARDIAN_FPS=12

# ---- 見守りプロフィール ----
PROFILE_PATH=config/profile.json
